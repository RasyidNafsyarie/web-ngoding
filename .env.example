# ============================================================
# NGODING SANTUY — Environment Variables Template
# Salin file ini ke .env dan isi nilainya
# JANGAN commit file .env ke repository!
# ============================================================

# ─── NextAuth.js ─────────────────────────────────────────────
# Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
# URL aplikasi (development: http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000

# ─── Database (Supabase PostgreSQL) ──────────────────────────
# Pooled connection (via PgBouncer, port 6543) — dipakai runtime/serverless
# Format: postgresql://[user]:[password]@[host]:6543/[dbname]?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1

# Direct connection (port 5432) — dipakai prisma migrate
# Format: postgresql://[user]:[password]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── OAuth Google ─────────────────────────────────────────────
# Dapatkan dari: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── OAuth GitHub ─────────────────────────────────────────────
# Dapatkan dari: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
